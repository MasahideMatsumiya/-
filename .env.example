# Shopify ストアドメイン (例: buddy-buddy.myshopify.com)
SHOPIFY_SHOP_DOMAIN=buddy-buddy.myshopify.com

# Shopify Admin API アクセストークン (shpat_... の形式)
# 管理画面 → 設定 → アプリと販売チャネル → アプリを開発 → カスタムアプリ
# 必要スコープ: read_customers, read_orders, read_customer_metafields
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxx

# 動物病院売上票のスプレッドシート ID
SPREADSHEET_ID_HOSPITAL=1XaLdUELAPoH-ru_joS4sNx7OKgxlprniZr_mAJAtkQM

# Google サービスアカウントの認証ファイルのパス
CREDENTIALS_FILE=credentials.json
