# AI Marketplace 環境変数
# ローカル開発: このファイルを .env にコピーして値を設定
# Railway: ダッシュボードの Variables タブで直接設定（.envは不要）

# ── App ──────────────────────────────────────────
DEBUG=false
# 本番用: openssl rand -hex 32 で生成
SECRET_KEY=your-secret-key-here

# ── Database ─────────────────────────────────────
# ローカル開発 (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./ai_marketplace.db
# Railway PostgreSQL (Railway が自動設定するので変更不要)
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ── Stripe ───────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# デプロイ後に Stripe Webhook を登録してから設定
STRIPE_WEBHOOK_SECRET=

# ── Email (Gmail の場合はアプリパスワードを使用) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@ai-marketplace.com

# ── Business Settings ─────────────────────────────
PLATFORM_FEE_PERCENT=10.0
DEFAULT_PRICE_USD=10.0
CURRENCY=usd
TAX_RATE_JP=0.10
