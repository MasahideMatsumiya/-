<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>出荷票 #{{ order.order_number }}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Hiragino Kaku Gothic Pro', 'Meiryo', sans-serif;
      font-size: 13px;
      color: #000;
      background: #fff;
      width: 210mm;
      padding: 8mm 10mm;
    }
    @media print {
      body { padding: 6mm 8mm; }
      @page { size: A4; margin: 0; }
    }

    /* ===== 上段：注文番号 ＋ お客様・愛犬名 ===== */
    .top-row {
      display: flex;
      align-items: baseline;
      gap: 16px;
      border-bottom: 3px solid #000;
      padding-bottom: 6px;
      margin-bottom: 8px;
    }
    .order-num {
      font-size: 36px;
      font-weight: bold;
      white-space: nowrap;
      min-width: 90px;
    }
    .customer-name {
      font-size: 24px;
      font-weight: bold;
      flex: 1;
      line-height: 1.3;
    }

    /* ===== 区分スタンプ（毎・都度・TR） ===== */
    .stamps {
      display: flex;
      gap: 8px;
      align-items: center;
      margin-bottom: 8px;
    }
    .stamp {
      font-size: 20px;
      font-weight: bold;
      border: 3px solid #000;
      border-radius: 4px;
      padding: 2px 10px;
      min-width: 44px;
      text-align: center;
    }
    .stamp.active {
      background: #000;
      color: #fff;
    }

    /* ===== メイン情報グリッド ===== */
    .main-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px 20px;
      margin-bottom: 8px;
    }
    .field-block { }
    .field-label {
      font-size: 10px;
      color: #555;
      font-weight: bold;
      margin-bottom: 2px;
    }
    .field-value {
      font-size: 16px;
      font-weight: bold;
      padding: 3px 6px;
      border: 1px solid #ccc;
      border-radius: 3px;
      min-height: 28px;
      background: #fafafa;
    }
    .field-value.red  { color: #cc0000; font-size: 28px; border: 2px solid #cc0000; background: #fff8f8; }
    .field-value.large { font-size: 20px; }

    /* ===== 配送サイズ ===== */
    .size-row {
      display: flex;
      gap: 10px;
      align-items: center;
      margin-bottom: 8px;
    }
    .size-label { font-size: 10px; color: #555; font-weight: bold; margin-right: 4px; }
    .size-box {
      font-size: 18px;
      font-weight: bold;
      border: 3px solid #000;
      border-radius: 4px;
      padding: 2px 12px;
      min-width: 48px;
      text-align: center;
    }
    .size-box.active { background: #000; color: #fff; }

    /* ===== 商品内容 ===== */
    .products-block {
      border: 1px solid #ccc;
      border-radius: 4px;
      padding: 6px 8px;
      margin-bottom: 8px;
      background: #fafafa;
    }
    .products-block .field-label { margin-bottom: 4px; }
    .product-line {
      font-size: 14px;
      padding: 2px 0;
      border-bottom: 1px dotted #ddd;
    }
    .product-line:last-child { border-bottom: none; }

    /* ===== プレゼント・都道府県 ===== */
    .bottom-grid {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px 20px;
      align-items: start;
    }
    .prefecture {
      font-size: 22px;
      font-weight: bold;
      padding: 4px 10px;
      border: 2px solid #000;
      border-radius: 4px;
      white-space: nowrap;
      text-align: center;
    }

    /* ===== 区切り線 ===== */
    .divider {
      border: none;
      border-top: 1px solid #ccc;
      margin: 8px 0;
    }
  </style>
</head>
<body>

  {%- comment -%}
    ── 愛犬メタフィールド (Helium Customer Fields) ──
    dog1_name   : app--960624--helium.new_singleline_text_field_4
    dog1_gender : app--960624--helium.1_1
    dog2_name   : app--960624--helium.new_singleline_text_field_2
    dog2_gender : app--960624--helium.new_singleline_text_field
    dog3_name   : app--960624--helium.new_singleline_text_field_3
    dog3_gender : app--960624--helium.1_3
  {%- endcomment -%}

  {%- assign ns = 'app--960624--helium' -%}
  {%- assign dog1_name   = order.customer.metafields[ns]['new_singleline_text_field_4'].value -%}
  {%- assign dog1_gender = order.customer.metafields[ns]['1_1'].value -%}
  {%- assign dog2_name   = order.customer.metafields[ns]['new_singleline_text_field_2'].value -%}
  {%- assign dog2_gender = order.customer.metafields[ns]['new_singleline_text_field'].value -%}
  {%- assign dog3_name   = order.customer.metafields[ns]['new_singleline_text_field_3'].value -%}
  {%- assign dog3_gender = order.customer.metafields[ns]['1_3'].value -%}

  {%- comment -%} 愛犬名を「〇〇ちゃん / くん」形式で結合 {%- endcomment -%}
  {%- assign dog_parts = "" -%}
  {%- for i in (1..3) -%}
    {%- if i == 1 -%}{%- assign dname = dog1_name -%}{%- assign dgender = dog1_gender -%}{%- endif -%}
    {%- if i == 2 -%}{%- assign dname = dog2_name -%}{%- assign dgender = dog2_gender -%}{%- endif -%}
    {%- if i == 3 -%}{%- assign dname = dog3_name -%}{%- assign dgender = dog3_gender -%}{%- endif -%}
    {%- if dname != blank -%}
      {%- if dgender == "女の子" -%}{%- assign suffix = "ちゃん" -%}{%- else -%}{%- assign suffix = "くん" -%}{%- endif -%}
      {%- assign label = dname | append: suffix -%}
      {%- if dog_parts == "" -%}{%- assign dog_parts = label -%}{%- else -%}{%- assign dog_parts = dog_parts | append: "、" | append: label -%}{%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%} 注文属性から配送希望日・時間帯を取得（追加詳細のキー名） {%- endcomment -%}
  {%- assign desired_date     = "" -%}
  {%- assign desired_time     = "" -%}
  {%- assign desired_date_alt = "" -%}
  {%- for attr in order.attributes -%}
    {%- if attr.key == "配送希望日" -%}
      {%- assign desired_date = attr.value -%}
    {%- endif -%}
    {%- if attr.key == "配送日の指定" -%}
      {%- assign desired_date_alt = attr.value -%}
    {%- endif -%}
    {%- if attr.key == "配送時間帯" -%}
      {%- assign desired_time = attr.value -%}
    {%- endif -%}
  {%- endfor -%}
  {%- comment -%} 配送希望日が空なら配送日の指定を使う {%- endcomment -%}
  {%- if desired_date == blank and desired_date_alt != blank and desired_date_alt != "なし" -%}
    {%- assign desired_date = desired_date_alt -%}
  {%- endif -%}

  {%- comment -%} 配送区分（タグから判定） {%- endcomment -%}
  {%- assign is_maicho  = false -%}
  {%- assign is_tsudo   = false -%}
  {%- assign is_trial   = false -%}
  {%- for tag in order.tags -%}
    {%- if tag == "毎" or tag == "定期" or tag == "subscription" -%}{%- assign is_maicho = true -%}{%- endif -%}
    {%- if tag == "都度" or tag == "一般" -%}{%- assign is_tsudo = true -%}{%- endif -%}
    {%- if tag == "TR" or tag == "trial" or tag == "トライアル" -%}{%- assign is_trial = true -%}{%- endif -%}
  {%- endfor -%}
  {%- if is_maicho == false and is_tsudo == false and is_trial == false -%}
    {%- assign is_tsudo = true -%}
  {%- endif -%}

  {%- comment -%}
    配送サイズを商品内容から自動判定
    CP : 食いつきトライアル・モリンガミルク・ウェットフード・トリーツ
    60 : ドライフード 1〜4袋
    80 : ドライフード 5〜10袋
    100: ドライフード 11袋〜
  {%- endcomment -%}
  {%- assign ship_size = "" -%}
  {%- assign dry_qty   = 0 -%}
  {%- assign is_cp     = false -%}
  {%- for item in order.line_items -%}
    {%- assign t = item.title | downcase -%}
    {%- if t contains "トライアル" or t contains "trial"
        or t contains "モリンガ"
        or t contains "ウェット" or t contains "wet"
        or t contains "トリーツ" or t contains "treat" or t contains "おやつ" -%}
      {%- assign is_cp = true -%}
    {%- elsif t contains "ドライ" or t contains "dry" -%}
      {%- assign dry_qty = dry_qty | plus: item.quantity -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if is_cp -%}
    {%- assign ship_size = "CP" -%}
  {%- elsif dry_qty >= 11 -%}
    {%- assign ship_size = "100" -%}
  {%- elsif dry_qty >= 5 -%}
    {%- assign ship_size = "80" -%}
  {%- elsif dry_qty >= 1 -%}
    {%- assign ship_size = "60" -%}
  {%- endif -%}

  {%- comment -%} 出荷日（今日 or フルフィルメント日） {%- endcomment -%}
  {%- assign ship_date = "now" | date: "%-m/%-d" -%}
  {%- if order.fulfillments.size > 0 -%}
    {%- assign ship_date = order.fulfillments.last.created_at | date: "%-m/%-d" -%}
  {%- endif -%}

  <!-- ===== 注文番号 ＋ お客様・愛犬名 ===== -->
  <div class="top-row">
    <div class="order-num">{{ order.order_number }}</div>
    <div class="customer-name">
      {{ order.shipping_address.last_name }}さま
      {%- if dog_parts != blank %}、{{ dog_parts }}{%- endif %}
    </div>
  </div>

  <!-- ===== 区分スタンプ ===== -->
  <div class="stamps">
    <span class="stamp{% if is_maicho %} active{% endif %}">毎</span>
    <span class="stamp{% if is_tsudo %} active{% endif %}">都度</span>
    <span class="stamp{% if is_trial %} active{% endif %}">TR</span>
  </div>

  <hr class="divider">

  <!-- ===== 日付・時間グリッド ===== -->
  <div class="main-grid">
    <div class="field-block">
      <div class="field-label">出荷日</div>
      <div class="field-value red">{{ ship_date }}</div>
    </div>
    <div class="field-block">
      <div class="field-label">配達希望日</div>
      <div class="field-value large">
        {%- if desired_date != blank %}{{ desired_date }}{%- else %}―{%- endif %}
      </div>
    </div>
    <div class="field-block" style="grid-column:1/-1;">
      <div class="field-label">配達希望時間</div>
      <div class="field-value large">
        {%- if desired_time != blank %}{{ desired_time }}{%- else %}指定なし{%- endif %}
      </div>
    </div>
  </div>

  <hr class="divider">

  <!-- ===== 配送サイズ ===== -->
  {%- assign sizes = "CP,60,80,100" | split: "," -%}
  <div class="size-row">
    <span class="size-label">配送サイズ</span>
    {%- for s in sizes -%}
      <span class="size-box{% if ship_size == s %} active{% endif %}">{{ s }}</span>
    {%- endfor -%}
  </div>

  <hr class="divider">

  <!-- ===== 商品内容 ===== -->
  <div class="products-block">
    <div class="field-label">商品内容</div>
    {%- for item in order.line_items -%}
      <div class="product-line">
        {{ item.title }}
        {%- if item.variant_title != blank and item.variant_title != "Default Title" %} ／ {{ item.variant_title }}{%- endif %}
        &nbsp;×{{ item.quantity }}
      </div>
    {%- endfor -%}
  </div>

  <!-- ===== プレゼント内容 ＋ 都道府県 ===== -->
  <div class="bottom-grid">
    <div>
      <div class="field-label">プレゼント内容</div>
      <div class="field-value" style="min-height:36px;">
        {%- assign gift_note = "" -%}
        {%- for attr in order.attributes -%}
          {%- if attr.key contains "プレゼント" or attr.key contains "gift" or attr.key contains "同梱" -%}
            {%- assign gift_note = attr.value -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if order.note contains "プレゼント" or order.note contains "同梱" -%}
          {%- assign gift_note = order.note -%}
        {%- endif -%}
        {%- if gift_note != blank %}{{ gift_note }}{%- else %}―{%- endif %}
      </div>
    </div>
    <div>
      <div class="field-label">配送都道府県</div>
      <div class="prefecture">{{ order.shipping_address.province }}</div>
    </div>
  </div>

</body>
</html>
