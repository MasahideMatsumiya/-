<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>出荷票 #{{ order.order_number }}</title>
  <style>
    * {
      margin: 0; padding: 0; box-sizing: border-box;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }
    body {
      font-family: 'Hiragino Kaku Gothic Pro', 'Meiryo', sans-serif;
      font-size: 12px;
      color: #000;
      background: #fff;
      width: 210mm;
      padding: 6mm 8mm;
    }
    @media print {
      body { padding: 5mm 7mm; }
      @page { size: A4; margin: 0; }
    }
    .section-label {
      font-size: 10px;
      font-weight: bold;
      color: #555;
      letter-spacing: 2px;
      margin-bottom: 4px;
    }
    .top-row {
      display: flex;
      align-items: baseline;
      gap: 12px;
      border-bottom: 3px solid #000;
      padding-bottom: 4px;
      margin-bottom: 6px;
    }
    .order-num { font-size: 32px; font-weight: bold; white-space: nowrap; }
    .customer-name { font-size: 20px; font-weight: bold; flex: 1; line-height: 1.3; }
    .stamps { display: flex; gap: 6px; align-items: center; margin-bottom: 6px; }
    .stamp {
      font-size: 16px; font-weight: bold;
      border: 2px solid #000; border-radius: 3px;
      padding: 1px 8px; min-width: 38px; text-align: center;
      background: #fff; color: #000;
    }
    .stamp.active { background: #000 !important; color: #fff !important; }
    .info-row {
      display: grid;
      grid-template-columns: 1fr 1fr 2fr;
      gap: 6px 12px;
      margin-bottom: 6px;
    }
    .field-label { font-size: 9px; color: #555; font-weight: bold; margin-bottom: 1px; }
    .field-value {
      font-size: 15px; font-weight: bold;
      padding: 2px 5px;
      border: 1px solid #ccc; border-radius: 2px;
      background: #fafafa; min-height: 24px;
    }
    .field-value.red {
      font-size: 26px;
      color: #cc0000 !important;
      border: 2px solid #cc0000;
      background: #fff !important;
    }
    .size-label { font-size: 9px; color: #555; font-weight: bold; margin-right: 2px; }
    .size-box {
      font-size: 16px; font-weight: bold;
      border: 2px solid #000; border-radius: 3px;
      padding: 2px 10px; min-width: 44px; text-align: center;
      background: #fff; color: #000;
    }
    .size-box.active { background: #000 !important; color: #fff !important; }
    .products-pref-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 6px 12px;
      align-items: start;
      margin-bottom: 4px;
    }
    .products-block {
      border: 1px solid #ccc; border-radius: 3px;
      padding: 4px 8px; background: #fafafa;
    }
    .product-line { font-size: 20px; font-weight: bold; padding: 1px 0; letter-spacing: 1px; }
    .prefecture {
      font-size: 18px; font-weight: bold;
      padding: 4px 8px;
      border: 2px solid #000; border-radius: 3px;
      white-space: nowrap; text-align: center; align-self: center;
    }
    .memo-block {
      border: 2px solid #e65c00;
      border-left: 6px solid #e65c00;
      border-radius: 2px;
      padding: 5px 8px;
      background: #fff8f4 !important;
      font-size: 14px; font-weight: bold;
      margin-bottom: 6px;
    }
    .memo-block .field-label { color: #e65c00; margin-bottom: 2px; }
    .checklist-category {
      font-size: 11px; font-weight: bold;
      background: #000; color: #fff !important;
      padding: 2px 8px; border-radius: 2px;
      display: inline-block; margin-bottom: 5px;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }
    .checklist { display: flex; flex-wrap: wrap; gap: 6px 16px; align-items: center; margin-bottom: 6px; }
    .check-item { display: flex; align-items: center; gap: 5px; font-size: 13px; font-weight: bold; }
    .checkbox { width: 18px; height: 18px; border: 2px solid #000; border-radius: 2px; display: inline-block; flex-shrink: 0; }
    .section-divider { border: none; border-top: 2px dashed #999; margin: 8px 0; }
    .payment-alert {
      border-radius: 3px; padding: 6px 10px; margin-bottom: 6px;
      font-size: 12px; font-weight: bold;
    }
    .payment-alert.konbini { background: #fff3cd !important; border: 2px solid #f0a000; color: #7a5000; }
    .payment-alert.cod { background: #e8f4fd !important; border: 2px solid #2196F3; color: #0d47a1; }
    .payment-alert-title { font-size: 14px; margin-bottom: 2px; }
    .size-address-row {
      display: grid; grid-template-columns: auto 1fr;
      gap: 6px 16px; align-items: center; margin-bottom: 6px;
    }
    .size-row { display: flex; gap: 8px; align-items: center; }
    .address-inline { font-size: 11px; line-height: 1.5; border-left: 2px solid #ccc; padding-left: 10px; }
    .detail-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px; }
    .detail-title { font-size: 11px; font-weight: bold; letter-spacing: 2px; color: #555; }
    .detail-meta { font-size: 10px; color: #555; }
    .items-table { width: 100%; border-collapse: collapse; margin-bottom: 4px; font-size: 11px; }
    .items-table th { background: #eee; border: 1px solid #999; padding: 3px 5px; text-align: left; }
    .items-table td { border: 1px solid #ccc; padding: 4px 5px; vertical-align: top; }
    .items-table .num { text-align: right; white-space: nowrap; }
    .totals-row { display: flex; justify-content: flex-end; margin-top: 4px; }
    .totals-table { font-size: 11px; border-collapse: collapse; }
    .totals-table td { padding: 2px 6px; }
    .totals-table td:last-child { text-align: right; font-weight: bold; min-width: 80px; }
    .totals-table .grand-total td { border-top: 2px solid #000; font-size: 13px; font-weight: bold; }
  </style>
</head>
<body>

  {%- assign ns = 'app--960624--helium' -%}
  {%- assign dog1_name   = order.customer.metafields[ns]['new_singleline_text_field_4'] -%}
  {%- assign dog1_gender = order.customer.metafields[ns]['1_1'] -%}
  {%- assign dog2_name   = order.customer.metafields[ns]['new_singleline_text_field_2'] -%}
  {%- assign dog2_gender = order.customer.metafields[ns]['new_singleline_text_field'] -%}
  {%- assign dog3_name   = order.customer.metafields[ns]['new_singleline_text_field_3'] -%}
  {%- assign dog3_gender = order.customer.metafields[ns]['1_3'] -%}

  {%- assign dog_parts = "" -%}
  {%- assign dog_names_arr   = dog1_name   | append: "," | append: dog2_name   | append: "," | append: dog3_name   | split: "," -%}
  {%- assign dog_genders_arr = dog1_gender | append: "," | append: dog2_gender | append: "," | append: dog3_gender | split: "," -%}
  {%- for dname in dog_names_arr -%}
    {%- if dname != blank -%}
      {%- assign dgender = dog_genders_arr[forloop.index0] -%}
      {%- if dgender == "女の子" -%}{%- assign suffix = "ちゃん" -%}{%- else -%}{%- assign suffix = "くん" -%}{%- endif -%}
      {%- assign label = dname | append: suffix -%}
      {%- if dog_parts == "" -%}{%- assign dog_parts = label -%}{%- else -%}{%- assign dog_parts = dog_parts | append: "、" | append: label -%}{%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  {%- assign desired_date = "" -%}
  {%- assign desired_time = "" -%}
  {%- for tag in order.tags -%}
    {%- if tag contains "配送希望日:" -%}
      {%- assign desired_date = tag | split: "配送希望日:" | last | strip -%}
    {%- endif -%}
    {%- if tag contains "配送時間帯:" -%}
      {%- assign desired_time = tag | split: "配送時間帯:" | last | strip -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if desired_date != blank -%}
    {%- assign desired_ts  = desired_date | date: "%s" | plus: 0 -%}
    {%- assign desired_dow = desired_date | date: "%w" | plus: 0 -%}
    {%- if desired_dow == 1 or desired_dow == 2 -%}
      {%- assign ship_ts = desired_ts | minus: 345600 -%}
    {%- else -%}
      {%- assign ship_ts = desired_ts | minus: 172800 -%}
    {%- endif -%}
    {%- assign ship_date = ship_ts | date: "%-m/%-d" -%}
  {%- else -%}
    {%- assign ship_date = "now" | date: "%-m/%-d" -%}
  {%- endif -%}

  {%- assign sub_count = 0 -%}
  {%- for tag in order.tags -%}
    {%- if tag contains "subscription-count:" -%}
      {%- assign sub_count = tag | split: "subscription-count:" | last | strip | plus: 0 -%}
    {%- endif -%}
  {%- endfor -%}

  {%- assign is_maicho = false -%}
  {%- assign is_tsudo  = false -%}
  {%- assign is_trial  = false -%}
  {%- for item in order.line_items -%}
    {%- assign t = item.title -%}
    {%- if t contains "定期便" -%}{%- assign is_maicho = true -%}{%- endif -%}
    {%- if t contains "都度購入" or t contains "モリンガミルク" or t contains "ウェットフード" -%}{%- assign is_tsudo = true -%}{%- endif -%}
    {%- if t contains "トライアル" -%}{%- assign is_trial = true -%}{%- endif -%}
  {%- endfor -%}

  {%- assign ship_size = "" -%}
  {%- assign dry_qty   = 0 -%}
  {%- for item in order.line_items -%}
    {%- if item.title contains "ドライフード" -%}
      {%- assign dry_qty = dry_qty | plus: item.quantity -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if dry_qty >= 11 -%}{%- assign ship_size = "100" -%}
  {%- elsif dry_qty >= 5 -%}{%- assign ship_size = "80" -%}
  {%- elsif dry_qty >= 1 -%}{%- assign ship_size = "60" -%}
  {%- else -%}{%- assign ship_size = "CP" -%}
  {%- endif -%}

  {%- assign gw = order.gateway | downcase -%}
  {%- assign is_konbini = false -%}
  {%- assign is_cod     = false -%}
  {%- if gw contains "konbini" or gw contains "convenience" or gw contains "komoju" -%}{%- assign is_konbini = true -%}{%- endif -%}
  {%- if gw contains "cod" or gw contains "cash_on_delivery" or gw contains "代引" -%}{%- assign is_cod = true -%}{%- endif -%}
  {%- assign total_num = order.total_price | plus: 0 -%}
  {%- if total_num <= 10000 -%}{%- assign cod_fee = "¥330（税抜¥300）" -%}
  {%- elsif total_num <= 30000 -%}{%- assign cod_fee = "¥440（税抜¥400）" -%}
  {%- else -%}{%- assign cod_fee = "要確認" -%}
  {%- endif -%}

  <div class="section-label">出 荷 票</div>

  <div class="top-row">
    <div class="order-num">{{ order.order_number }}</div>
    <div class="customer-name">
      {{ order.shipping_address.last_name }}さま
      {%- if dog_parts != blank %}、{{ dog_parts }}{%- endif %}
    </div>
  </div>

  <div class="stamps">
    <span class="stamp{% if is_maicho %} active{% endif %}">毎</span>
    <span class="stamp{% if is_tsudo %} active{% endif %}">都度</span>
    <span class="stamp{% if is_trial %} active{% endif %}">TR</span>
  </div>

  {%- if order.note != blank -%}
  <div class="memo-block">
    <div class="field-label">メモ（配達日変更確認）</div>
    <div>{{ order.note }}</div>
  </div>
  {%- endif -%}

  {%- if is_konbini and order.financial_status == "pending" -%}
  <div class="payment-alert konbini">
    <div class="payment-alert-title">⚠️ コンビニ決済 保留中</div>
    決済完了確認後に発送してください。
  </div>
  {%- endif -%}
  {%- if is_cod -%}
  <div class="payment-alert cod">
    <div class="payment-alert-title">💴 代金引換（代引き）</div>
    代引き手数料：{{ cod_fee }}　／　商品代金 ¥{{ order.total_price | money_without_currency }} + 手数料を回収
  </div>
  {%- endif -%}

  <div class="info-row">
    <div>
      <div class="field-label">出荷日</div>
      <div class="field-value red">{{ ship_date }}</div>
    </div>
    <div>
      <div class="field-label">配達希望日</div>
      <div class="field-value">
        {%- if desired_date != blank %}{{ desired_date | date: "%-m/%-d" }}{%- else %}―{%- endif %}
      </div>
    </div>
    <div>
      <div class="field-label">配達希望時間</div>
      <div class="field-value">
        {%- if desired_time != blank and desired_time != "指定なし" %}{{ desired_time }}{%- else %}指定なし{%- endif %}
      </div>
    </div>
  </div>

  {%- assign sizes = "CP,60,80,100" | split: "," -%}
  <div class="size-address-row">
    <div class="size-row">
      <span class="size-label">配送サイズ</span>
      {%- for s in sizes -%}
        <span class="size-box{% if ship_size == s %} active{% endif %}">{{ s }}</span>
      {%- endfor -%}
    </div>
    <div class="address-inline">
      〒{{ order.shipping_address.zip }}&nbsp;
      {{ order.shipping_address.province }}{{ order.shipping_address.city }}{{ order.shipping_address.address1 }}
      {%- if order.shipping_address.address2 != blank %} {{ order.shipping_address.address2 }}{%- endif %}<br>
      {{ order.shipping_address.last_name }}&nbsp;{{ order.shipping_address.first_name }}
    </div>
  </div>

  <div class="products-pref-row">
    <div class="products-block">
      <div class="field-label">商品内容</div>
      {%- for item in order.line_items -%}
        {%- assign t = item.title -%}
        {%- assign abbr = "" -%}
        {%- if t contains "ドライフード" -%}
          {%- if t contains "チキン" -%}{%- assign abbr = "BC" -%}
          {%- elsif t contains "ベニソン" -%}{%- assign abbr = "BV" -%}
          {%- elsif t contains "ポーク" -%}{%- assign abbr = "BP" -%}
          {%- endif -%}
        {%- elsif t contains "ウェットフード" -%}
          {%- if t contains "チキン" -%}{%- assign abbr = "WC" -%}
          {%- elsif t contains "ホース" -%}{%- assign abbr = "WH" -%}
          {%- endif -%}
        {%- elsif t contains "モリンガミルク" -%}{%- assign abbr = "MM" -%}
        {%- elsif t contains "トライアル" -%}{%- assign abbr = "食いつき" -%}
        {%- endif -%}
        <div class="product-line">
          {%- if abbr != blank %}{{ abbr }}&nbsp;&nbsp;{{ item.quantity }}{%- else %}{{ item.title }}&nbsp;×{{ item.quantity }}{%- endif %}
        </div>
      {%- endfor -%}
    </div>
    <div class="prefecture">{{ order.shipping_address.province }}</div>
  </div>

  <div class="field-label" style="margin-bottom:4px;">同梱チェック</div>

  {%- if is_trial -%}
    <div class="checklist-category">食いつきトライアル</div>
    <div class="checklist">
      <label class="check-item"><span class="checkbox"></span>パンフレット</label>
      <label class="check-item"><span class="checkbox"></span>お客様の声</label>
      <label class="check-item"><span class="checkbox"></span>定期便のご案内</label>
      <label class="check-item"><span class="checkbox"></span>¥500クーポン券</label>
      <label class="check-item"><span class="checkbox"></span>LINEチラシ</label>
    </div>
  {%- elsif is_maicho -%}
    {%- if sub_count == 1 -%}
      <div class="checklist-category">定期トライアル（1回目）</div>
      <div class="checklist">
        <label class="check-item"><span class="checkbox"></span>パンフレット</label>
        <label class="check-item"><span class="checkbox"></span>月刊誌</label>
        <label class="check-item"><span class="checkbox"></span>サンクスカード</label>
        <label class="check-item"><span class="checkbox"></span>お客様の声</label>
        <label class="check-item"><span class="checkbox"></span>食べ方ガイド</label>
      </div>
    {%- elsif sub_count == 2 -%}
      <div class="checklist-category">定期便２回目</div>
      <div class="checklist">
        <label class="check-item"><span class="checkbox"></span>月刊誌</label>
        <label class="check-item"><span class="checkbox"></span>サンクスカード</label>
        <label class="check-item"><span class="checkbox"></span>定期便クーポン</label>
        <label class="check-item"><span class="checkbox"></span>次回ウェットプレゼントチラシ</label>
        <label class="check-item"><span class="checkbox"></span>LINEチラシ</label>
      </div>
    {%- elsif sub_count == 3 -%}
      <div class="checklist-category">定期便３回目</div>
      <div class="checklist">
        <label class="check-item"><span class="checkbox"></span>月刊誌</label>
        <label class="check-item"><span class="checkbox"></span>サンクスカード</label>
        <label class="check-item"><span class="checkbox"></span>定期便クーポン</label>
        <label class="check-item"><span class="checkbox"></span>ウェットプレゼント</label>
      </div>
    {%- else -%}
      <div class="checklist-category">定期便（{{ sub_count }}回目）</div>
      <div class="checklist">
        <label class="check-item"><span class="checkbox"></span>月刊誌</label>
        <label class="check-item"><span class="checkbox"></span>サンクスカード</label>
        <label class="check-item"><span class="checkbox"></span>定期便クーポン</label>
      </div>
    {%- endif -%}
  {%- elsif is_tsudo -%}
    <div class="checklist-category">都度</div>
    <div class="checklist">
      <label class="check-item"><span class="checkbox"></span>パンフレット</label>
      <label class="check-item"><span class="checkbox"></span>月刊誌</label>
      <label class="check-item"><span class="checkbox"></span>サンクスカード</label>
      <label class="check-item"><span class="checkbox"></span>LINEチラシ</label>
      <label class="check-item"><span class="checkbox"></span>食べ方ガイド</label>
      <label class="check-item"><span class="checkbox"></span>お客様の声</label>
    </div>
  {%- endif -%}

  <hr class="section-divider">

  <div class="detail-header">
    <div class="detail-title">明 細 表</div>
    <div class="detail-meta">
      注文番号 {{ order.order_number }}　／　注文日 {{ order.created_at | date: "%Y年%-m月%-d日" }}　／　{{ order.shipping_lines.first.title }}
    </div>
  </div>

  <table class="items-table">
    <thead>
      <tr>
        <th style="width:55%;">商品名</th>
        <th style="width:12%;text-align:right;">単価</th>
        <th style="width:10%;text-align:right;">数量</th>
        <th style="width:13%;text-align:right;">合計</th>
      </tr>
    </thead>
    <tbody>
      {%- for item in order.line_items -%}
      <tr>
        <td>
          {{ item.title }}
          {%- if item.variant_title != blank and item.variant_title != "Default Title" %}<br><span style="color:#666;font-size:10px;">{{ item.variant_title }}</span>{%- endif %}
        </td>
        <td class="num">¥{{ item.price | money_without_currency }}</td>
        <td class="num">{{ item.quantity }}</td>
        <td class="num">¥{{ item.final_line_price | money_without_currency }}</td>
      </tr>
      {%- endfor -%}
    </tbody>
  </table>

  <div class="totals-row">
    <table class="totals-table">
      <tr><td>小計</td><td>¥{{ order.subtotal_price | money_without_currency }}</td></tr>
      <tr><td>配送</td><td>¥{{ order.shipping_price | money_without_currency }}</td></tr>
      <tr><td>消費税</td><td>¥{{ order.total_tax | money_without_currency }}</td></tr>
      <tr class="grand-total"><td>合計</td><td>¥{{ order.total_price | money_without_currency }}</td></tr>
    </table>
  </div>

</body>
</html>
