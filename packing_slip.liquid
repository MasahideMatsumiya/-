<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>出荷票 #{{ order.order_number }}</title>
  <style>
    * {
      margin: 0; padding: 0; box-sizing: border-box;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }
    body {
      font-family: 'Hiragino Kaku Gothic Pro', 'Meiryo', sans-serif;
      font-size: 13px;
      color: #000;
      background: #fff;
      width: 210mm;
      padding: 8mm 10mm;
    }
    @media print {
      body { padding: 6mm 8mm; }
      @page { size: A4; margin: 0; }
    }

    /* ===== 上段：注文番号 ＋ お客様・愛犬名 ===== */
    .top-row {
      display: flex;
      align-items: baseline;
      gap: 16px;
      border-bottom: 3px solid #000;
      padding-bottom: 6px;
      margin-bottom: 8px;
    }
    .order-num {
      font-size: 36px;
      font-weight: bold;
      white-space: nowrap;
      min-width: 90px;
    }
    .customer-name {
      font-size: 22px;
      font-weight: bold;
      flex: 1;
      line-height: 1.4;
    }

    /* ===== 区分スタンプ（毎・都度・TR） ===== */
    .stamps {
      display: flex;
      gap: 8px;
      align-items: center;
      margin-bottom: 8px;
    }
    .stamp {
      font-size: 20px;
      font-weight: bold;
      border: 3px solid #000;
      border-radius: 4px;
      padding: 2px 10px;
      min-width: 44px;
      text-align: center;
      background: #fff;
      color: #000;
    }
    .stamp.active {
      background: #000 !important;
      color: #fff !important;
    }

    /* ===== メイン情報グリッド ===== */
    .main-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px 20px;
      margin-bottom: 8px;
    }
    .field-label {
      font-size: 10px;
      color: #555;
      font-weight: bold;
      margin-bottom: 2px;
    }
    .field-value {
      font-size: 18px;
      font-weight: bold;
      padding: 3px 6px;
      border: 1px solid #ccc;
      border-radius: 3px;
      min-height: 30px;
      background: #fafafa;
    }
    .field-value.red {
      color: #cc0000 !important;
      font-size: 30px;
      border: 2px solid #cc0000;
      background: #fff !important;
    }

    /* ===== 配送サイズ ===== */
    .size-row {
      display: flex;
      gap: 10px;
      align-items: center;
      margin-bottom: 8px;
    }
    .size-label { font-size: 10px; color: #555; font-weight: bold; margin-right: 4px; }
    .size-box {
      font-size: 20px;
      font-weight: bold;
      border: 3px solid #000;
      border-radius: 4px;
      padding: 3px 14px;
      min-width: 52px;
      text-align: center;
      background: #fff;
      color: #000;
    }
    .size-box.active {
      background: #000 !important;
      color: #fff !important;
    }

    /* ===== 商品内容 ===== */
    .products-block {
      border: 1px solid #ccc;
      border-radius: 4px;
      padding: 6px 10px;
      margin-bottom: 8px;
      background: #fafafa;
    }
    .product-line {
      font-size: 22px;
      font-weight: bold;
      padding: 3px 0;
      border-bottom: 1px dotted #ccc;
      letter-spacing: 1px;
    }
    .product-line:last-child { border-bottom: none; }

    /* ===== プレゼント・都道府県 ===== */
    .bottom-grid {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px 20px;
      align-items: start;
    }
    .prefecture {
      font-size: 22px;
      font-weight: bold;
      padding: 4px 10px;
      border: 2px solid #000;
      border-radius: 4px;
      white-space: nowrap;
      text-align: center;
    }

    /* ===== 区切り線 ===== */
    .divider {
      border: none;
      border-top: 1px solid #ccc;
      margin: 8px 0;
    }
  </style>
</head>
<body>

  {%- comment -%}
    ── 愛犬メタフィールド (Helium Customer Fields) ──
    dog1_name   : app--960624--helium / new_singleline_text_field_4
    dog1_gender : app--960624--helium / 1_1
    dog2_name   : app--960624--helium / new_singleline_text_field_2
    dog2_gender : app--960624--helium / new_singleline_text_field
    dog3_name   : app--960624--helium / new_singleline_text_field_3
    dog3_gender : app--960624--helium / 1_3
  {%- endcomment -%}

  {%- assign ns = 'app--960624--helium' -%}
  {%- assign dog1_name   = order.customer.metafields[ns]['new_singleline_text_field_4'] -%}
  {%- assign dog1_gender = order.customer.metafields[ns]['1_1'] -%}
  {%- assign dog2_name   = order.customer.metafields[ns]['new_singleline_text_field_2'] -%}
  {%- assign dog2_gender = order.customer.metafields[ns]['new_singleline_text_field'] -%}
  {%- assign dog3_name   = order.customer.metafields[ns]['new_singleline_text_field_3'] -%}
  {%- assign dog3_gender = order.customer.metafields[ns]['1_3'] -%}

  {%- comment -%} 愛犬名を「〇〇ちゃん / くん」形式で結合 {%- endcomment -%}
  {%- assign dog_parts = "" -%}
  {%- assign dog_names_arr = dog1_name | append: "," | append: dog2_name | append: "," | append: dog3_name | split: "," -%}
  {%- assign dog_genders_arr = dog1_gender | append: "," | append: dog2_gender | append: "," | append: dog3_gender | split: "," -%}
  {%- for dname in dog_names_arr -%}
    {%- if dname != blank -%}
      {%- assign dgender = dog_genders_arr[forloop.index0] -%}
      {%- if dgender == "女の子" -%}{%- assign suffix = "ちゃん" -%}{%- else -%}{%- assign suffix = "くん" -%}{%- endif -%}
      {%- assign label = dname | append: suffix -%}
      {%- if dog_parts == "" -%}{%- assign dog_parts = label -%}{%- else -%}{%- assign dog_parts = dog_parts | append: "、" | append: label -%}{%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%}
    注文属性から配送希望日・時間帯を取得
    Shopify Order Printer では order.note_attributes を使う
    各要素は .name と .value を持つ
  {%- endcomment -%}
  {%- assign desired_date     = "" -%}
  {%- assign desired_time     = "" -%}
  {%- assign desired_date_alt = "" -%}
  {%- for attr in order.note_attributes -%}
    {%- if attr.name == "配送希望日" -%}
      {%- assign desired_date = attr.value -%}
    {%- endif -%}
    {%- if attr.name == "配送日の指定" -%}
      {%- assign desired_date_alt = attr.value -%}
    {%- endif -%}
    {%- if attr.name == "配送時間帯" -%}
      {%- assign desired_time = attr.value -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if desired_date == blank and desired_date_alt != blank and desired_date_alt != "なし" -%}
    {%- assign desired_date = desired_date_alt -%}
  {%- endif -%}

  {%- comment -%}
    出荷日 = 配達希望日の2営業日前
    月(1)・火(2) → 週末をまたぐため4日前
    水(3)〜金(5) → 2日前
    配達希望日が未設定の場合は今日を使用
  {%- endcomment -%}
  {%- if desired_date != blank -%}
    {%- assign desired_ts  = desired_date | date: "%s" | plus: 0 -%}
    {%- assign desired_dow = desired_date | date: "%w" | plus: 0 -%}
    {%- if desired_dow == 1 or desired_dow == 2 -%}
      {%- assign ship_ts = desired_ts | minus: 345600 -%}
    {%- else -%}
      {%- assign ship_ts = desired_ts | minus: 172800 -%}
    {%- endif -%}
    {%- assign ship_date = ship_ts | date: "%-m/%-d" -%}
  {%- else -%}
    {%- assign ship_date = "now" | date: "%-m/%-d" -%}
  {%- endif -%}

  {%- comment -%}
    配送区分を商品名から判定
    毎  : 定期便を含む
    都度 : 都度購入・モリンガミルク・ウェットフードを含む
    TR  : トライアルを含む
  {%- endcomment -%}
  {%- assign is_maicho = false -%}
  {%- assign is_tsudo  = false -%}
  {%- assign is_trial  = false -%}
  {%- for item in order.line_items -%}
    {%- assign t = item.title -%}
    {%- if t contains "定期便" -%}{%- assign is_maicho = true -%}{%- endif -%}
    {%- if t contains "都度購入" or t contains "モリンガミルク" or t contains "ウェットフード" -%}{%- assign is_tsudo = true -%}{%- endif -%}
    {%- if t contains "トライアル" -%}{%- assign is_trial = true -%}{%- endif -%}
  {%- endfor -%}

  {%- comment -%}
    配送サイズを商品内容から自動判定
    CP  : ウェットフード・モリンガミルク・トライアル
    60  : ドライフード 1〜4袋
    80  : ドライフード 5〜10袋
    100 : ドライフード 11袋〜
  {%- endcomment -%}
  {%- assign ship_size = "" -%}
  {%- assign dry_qty   = 0 -%}
  {%- assign is_cp     = false -%}
  {%- for item in order.line_items -%}
    {%- assign t = item.title -%}
    {%- if t contains "ウェットフード" or t contains "モリンガミルク" or t contains "トライアル" -%}
      {%- assign is_cp = true -%}
    {%- elsif t contains "ドライフード" -%}
      {%- assign dry_qty = dry_qty | plus: item.quantity -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if is_cp -%}
    {%- assign ship_size = "CP" -%}
  {%- elsif dry_qty >= 11 -%}
    {%- assign ship_size = "100" -%}
  {%- elsif dry_qty >= 5 -%}
    {%- assign ship_size = "80" -%}
  {%- elsif dry_qty >= 1 -%}
    {%- assign ship_size = "60" -%}
  {%- endif -%}

  <!-- ===== 注文番号 ＋ お客様・愛犬名 ===== -->
  <div class="top-row">
    <div class="order-num">{{ order.order_number }}</div>
    <div class="customer-name">
      {{ order.shipping_address.last_name }}さま
      {%- if dog_parts != blank %}　{{ dog_parts }}{%- endif %}
    </div>
  </div>

  <!-- ===== 区分スタンプ ===== -->
  <div class="stamps">
    <span class="stamp{% if is_maicho %} active{% endif %}">毎</span>
    <span class="stamp{% if is_tsudo %} active{% endif %}">都度</span>
    <span class="stamp{% if is_trial %} active{% endif %}">TR</span>
  </div>

  <hr class="divider">

  <!-- ===== 日付・時間グリッド ===== -->
  <div class="main-grid">
    <div class="field-block">
      <div class="field-label">出荷日</div>
      <div class="field-value red">{{ ship_date }}</div>
    </div>
    <div class="field-block">
      <div class="field-label">配達希望日</div>
      <div class="field-value">
        {%- if desired_date != blank -%}
          {{ desired_date | date: "%-m/%-d" }}
        {%- else -%}―{%- endif %}
      </div>
    </div>
    <div class="field-block" style="grid-column:1/-1;">
      <div class="field-label">配達希望時間</div>
      <div class="field-value">
        {%- if desired_time != blank and desired_time != "指定なし" %}{{ desired_time }}{%- else %}指定なし{%- endif %}
      </div>
    </div>
  </div>

  <hr class="divider">

  <!-- ===== 配送サイズ ===== -->
  {%- assign sizes = "CP,60,80,100" | split: "," -%}
  <div class="size-row">
    <span class="size-label">配送サイズ</span>
    {%- for s in sizes -%}
      <span class="size-box{% if ship_size == s %} active{% endif %}">{{ s }}</span>
    {%- endfor -%}
  </div>

  <hr class="divider">

  <!-- ===== 商品内容（略称表示） ===== -->
  <div class="products-block">
    <div class="field-label">商品内容</div>
    {%- for item in order.line_items -%}
      {%- assign t = item.title -%}
      {%- assign abbr = "" -%}
      {%- if t contains "ドライフード" -%}
        {%- if t contains "チキン" -%}{%- assign abbr = "BC" -%}
        {%- elsif t contains "ベニソン" -%}{%- assign abbr = "BV" -%}
        {%- elsif t contains "ポーク" -%}{%- assign abbr = "BP" -%}
        {%- endif -%}
      {%- elsif t contains "ウェットフード" -%}
        {%- if t contains "チキン" -%}{%- assign abbr = "WC" -%}
        {%- elsif t contains "ホース" -%}{%- assign abbr = "WH" -%}
        {%- endif -%}
      {%- elsif t contains "モリンガミルク" -%}
        {%- assign abbr = "MM" -%}
      {%- elsif t contains "トライアル" -%}
        {%- assign abbr = "食いつき" -%}
      {%- endif -%}
      <div class="product-line">
        {%- if abbr != blank -%}
          {{ abbr }}&nbsp;&nbsp;{{ item.quantity }}
        {%- else -%}
          {{ item.title }}&nbsp;×{{ item.quantity }}
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  <!-- ===== 都道府県 ===== -->
  <div class="bottom-grid">
    <div></div>
    <div>
      <div class="field-label">配送都道府県</div>
      <div class="prefecture">{{ order.shipping_address.province }}</div>
    </div>
  </div>

  <!-- ===== デバッグ（確認後に削除） ===== -->
  <div style="border:3px solid red;padding:12px;margin-top:20px;font-size:15px;">
    <div><strong>▼ note_attributes:</strong></div>
    {%- for attr in order.note_attributes -%}
      <div>{{ attr.name }} = {{ attr.value }}</div>
    {%- else -%}
      <div style="color:red;">→ note_attributes は空</div>
    {%- endfor -%}
    <div style="margin-top:10px;"><strong>▼ note:</strong> {{ order.note }}</div>
  </div>

</body>
</html>
